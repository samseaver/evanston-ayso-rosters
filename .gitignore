# Source data archive — contains all PII, never commit
AYSO_Rosters.tar.gz
AYSO_Rosters/

# Any future raw exports / spreadsheets that might land in this folder
*.xlsx
*.csv
*.tsv

# But allow committed examples and test fixtures that are explicitly sanitized
!examples/**/*.csv
!examples/**/*.tsv
!**/tests/fixtures/**/*.csv
!**/tests/fixtures/**/*.tsv

# Python / OS
__pycache__/
*.py[cod]
.DS_Store
._*
